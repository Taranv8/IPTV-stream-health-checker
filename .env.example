# --- MongoDB ---
MONGO_URI=mongodb+srv://tandam:61UMWpsKROnyAvXm@cluster0.cqnwuiv.mongodb.net/IPTV?appName=Cluster0
DB_NAME=IPTV
COLLECTION=channelinfo

# --- Timing ---
# Delay between checking each individual stream URL (ms). Keeps checks sequential within a
# channel and gentle on the source servers.
DELAY_BETWEEN_CHECKS_MS=2000

# How long to wait after a full pass over every channel before starting the next cycle (ms).
CYCLE_INTERVAL_MS=300000

# How many channels to process concurrently. Default 1 = strictly one stream URL checked at a
# time across the whole run, exactly as originally specified. Raise this (e.g. 3-5) on large
# collections to speed up a full pass - each channel's own streamUrls[] is still always checked
# strictly one-at-a-time regardless of this setting; this only parallelizes *across* channels.
CHANNEL_CONCURRENCY=1

# --- Network ---
MANIFEST_TIMEOUT_MS=8000
SEGMENT_TIMEOUT_MS=10000
# How many segments to sample from the media playlist to measure real download throughput/jitter.
SEGMENT_SAMPLE_COUNT=2
# Retries on *transient* failures (timeouts, 5xx, connection resets) before giving up on an
# attempt. Permanent failures (404/401/403/etc) are never retried, since retrying can't fix them.
MAX_RETRIES=2

# Cheaply HEAD-check every other quality variant in a master playlist (not just the best one) so
# you know whether ABR fallback will actually work. Set to "false" to skip (fewer requests/check).
TEST_VARIANT_FALLBACK=true

# Verify AES-128/SAMPLE-AES key delivery URLs (HLS) and DASH license-acquisition URLs are
# reachable - segments can download fine and still be unplayable if the key endpoint is dead.
# Set to "false" to skip.
KEY_URI_CHECK=true

# --- Smart scoring ---
# EMA smoothing factor for the persisted healthScore (0-1). Higher = more reactive to the latest
# check; lower = more resistant to single blips. Default 0.4 favors recent checks but doesn't
# overreact to one bad sample.
EMA_ALPHA=0.4
# How many consecutive fully-failed checks are needed before a stream is force-scored to 0
# ("confirmed dead") regardless of its smoothed EMA history.
CONSECUTIVE_FAILURES_TO_CONFIRM_DEAD=3

# --- Adaptive check scheduling ---
# Dead streams back off exponentially (base * 2^failures, capped) instead of being re-checked
# every cycle - saves time/bandwidth on known-dead links while still eventually retrying them.
DEAD_BACKOFF_BASE_MS=60000
DEAD_BACKOFF_MAX_MS=3600000
# Degraded/flaky streams are checked *more* often than the normal cadence, since resolving their
# ranking matters most while still unstable.
DEGRADED_CHECK_INTERVAL_MS=120000
# Healthy streams' recheck interval. 0 = eligible every cycle (default/simplest).
ALIVE_CHECK_INTERVAL_MS=0

# --- Web server (Railway health check / status page) ---
PORT=3000
